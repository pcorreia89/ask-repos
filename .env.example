ANTHROPIC_API_KEY=

# Embedding provider: "ollama" (default) or "voyage"
# EMBEDDING_PROVIDER=ollama

# --- Ollama (default) ---
# Requires Ollama running locally: https://ollama.com
# Pull the model first: ollama pull nomic-embed-text
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=nomic-embed-text

# --- Voyage (set EMBEDDING_PROVIDER=voyage) ---
# VOYAGE_API_KEY=
# VOYAGE_MODEL=voyage-code-3

# Optional overrides
ANTHROPIC_MODEL=claude-haiku-4-5
ASK_REPOS_TOP_K=12
ASK_REPOS_MAX_TOKENS=1024

# Centralized index location (defaults to ~/.ask-repos/indexes/)
# ASK_REPOS_INDEX_BASE=

# Admin UI (served on `serve` command)
ADMIN_USER=admin
ADMIN_PASSWORD=admin
# ADMIN_PORT=3000

# Slack bot (required for `serve` command)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Git provider tokens (required for `sync` command)
# BITBUCKET_TOKEN=
# GITHUB_TOKEN=
